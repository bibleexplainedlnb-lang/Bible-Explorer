# ─── AI Content Generation (optional) ─────────────────────────────────────────
#
# Required only if you use the AI content generation feature (/admin → generate).
# Sign up at https://platform.openai.com and create an API key.
#
# Alternatively, use the Replit AI Integrations proxy — keys are auto-provisioned
# when running on Replit (no configuration needed).

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...

# If using Replit AI Integrations, these are set automatically:
# AI_INTEGRATIONS_OPENAI_BASE_URL=...
# AI_INTEGRATIONS_OPENAI_API_KEY=...
